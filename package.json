{
  "name": "intern-notifs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal internship notification and tracking foundation",
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run test/integration.workflow.test.ts",
    "test:watch": "vitest",
    "cdk": "cdk --app 'npx tsx infra/app.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.883.0",
    "@aws-sdk/client-sesv2": "^3.883.0",
    "@aws-sdk/client-ssm": "^3.883.0",
    "@aws-sdk/lib-dynamodb": "^3.883.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "aws-cdk": "^2.220.0",
    "aws-cdk-lib": "^2.220.0",
    "constructs": "^10.4.2",
    "esbuild": "^0.25.9",
    "eslint": "^9.35.0",
    "@eslint/js": "^9.35.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "tsx": "^4.20.5",
    "vitest": "^3.2.4"
  }
}
